// ============================================================================

const OverviewCard: React.FC<OverviewCardProps> = React.memo(({
  title,
  value,
  subtitle,
  icon: IconComponent,
  trend,
  accentColor,
  progress,
  badgeText,
  onClick,
}) => {
  const styles = colorStyles[accentColor] || colorStyles.indigo;
  const clampedProgress = useMemo(
    () => (typeof progress === 'number' ? clamp(progress, 0, 100) : undefined),
    [progress]
  );

  return (
    <motion.div
      whileHover={{ y: -3, transition: { duration: 0.2 } }}
      whileTap={{ scale: 0.98 }}
      initial={{ opacity: 0, y: 12 }}
      animate={{ opacity: 1, y: 0 }}
      transition={{ duration: 0.3 }}
      tabIndex={0}
      role="button"
      aria-label={`${title}: ${value}. ${subtitle || ''}`}
      onClick={onClick}
      onKeyDown={(e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          onClick?.();
        }
      }}
      className={`group relative flex flex-col justify-between overflow-hidden rounded-2xl border bg-white p-5 shadow-sm transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 dark:bg-slate-900 ${styles.border}`}
    >
      <div>
        {/* Card Header: Title & Icon */}
        <div className="flex items-start justify-between space-x-3">
          <div className="flex flex-col space-y-1">
            <span className="text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400">
              {title}
            </span>
            {badgeText && (
              <span
                className={`inline-flex w-fit items-center rounded-full border px-2 py-0.5 text-[10px] font-semibold ${styles.badge}`}
              >
                {badgeText}
              </span>
            )}
          </div>
          <div
            className={`flex h-10 w-10 shrink-0 items-center justify-center rounded-xl transition-colors ${styles.iconBg}`}
          >
            <IconComponent className="h-5 w-5" aria-hidden="true" />
          </div>
        </div>

        {/* Card Value with CountUp Animation */}
        <div className="mt-3 flex items-baseline justify-between">
          <span className="text-3xl font-extrabold tracking-tight text-slate-900 dark:text-slate-100">
            <AnimatedValue value={value} />
          </span>
        </div>

        {/* Trend & Subtitle */}
        <div className="mt-2 flex items-center space-x-2">
          {trend && (
            <span
              className={`inline-flex items-center space-x-0.5 text-xs font-bold ${
                trend.direction === 'up'
                  ? 'text-emerald-600 dark:text-emerald-400'
                  : trend.direction === 'down'
                  ? 'text-rose-600 dark:text-rose-400'
                  : 'text-slate-500 dark:text-slate-400'
              }`}
            >
              {trend.direction === 'up' && <ArrowUpRight className="h-3.5 w-3.5" aria-hidden="true" />}
              {trend.direction === 'down' && <ArrowDownRight className="h-3.5 w-3.5" aria-hidden="true" />}
              <span>{trend.value}</span>
            </span>
          )}

          {subtitle && (
            <span className="text-xs text-slate-500 dark:text-slate-400 truncate">
              {subtitle}
            </span>
          )}
        </div>
      </div>

      {/* Progress Bar (Clamped 0-100) */}
      {typeof clampedProgress === 'number' && (
        <div className="mt-4 pt-2">
          <div className="flex items-center justify-between text-[11px] font-medium text-slate-400">
            <span>Score Efficiency</span>
            <span>{clampedProgress}%</span>
          </div>
          <div className="mt-1 h-1.5 w-full overflow-hidden rounded-full bg-slate-100 dark:bg-slate-800">
            <motion.div
              initial={{ width: 0 }}
              animate={{ width: `${clampedProgress}%` }}
              transition={{ duration: 0.8, delay: 0.2, ease: 'easeOut' }}
              className={`h-full rounded-full ${styles.bar}`}
            />
          </div>
        </div>
      )}
    </motion.div>
  );
});

OverviewCard.displayName = 'OverviewCard';

