// ============================================================================
// 3. ANIMATED COUNT UP COMPONENT
// ============================================================================

const AnimatedValue: React.FC<{ value: string | number }> = React.memo(({ value }) => {
  const parsedValue = useMemo(() => {
    if (typeof value === 'number') return { numeric: value, prefix: '', suffix: '', decimals: 0 };
    const match = value.match(/^([^\d-]*)([-+]?\d*\.?\d+)(.*)$/);
    if (!match) return null;
    const [, prefix, numStr, suffix] = match;
    const num = parseFloat(numStr);
    const decimals = numStr.includes('.') ? numStr.split('.')[1].length : 0;
    return { numeric: num, prefix, suffix, decimals };
  }, [value]);

  const spring = useSpring(0, { mass: 0.8, stiffness: 75, damping: 15 });
  const animatedText = useTransform(spring, (latest) => {
    if (!parsedValue) return String(value);
    const { prefix, suffix, decimals } = parsedValue;
    return `${prefix}${latest.toFixed(decimals)}${suffix}`;
  });

  useEffect(() => {
    if (parsedValue) {
      spring.set(parsedValue.numeric);
    }
  }, [parsedValue, spring]);

  if (!parsedValue) {
    return <span>{value}</span>;
  }

  return <motion.span>{animatedText}</motion.span>;
});

AnimatedValue.displayName = 'AnimatedValue';

