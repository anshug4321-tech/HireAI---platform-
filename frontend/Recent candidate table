  { id: 'c-1', name: 'Eleanor Pena', email: 'eleanor.pena@example.com', role: 'Senior Frontend Engineer', appliedDate: '2023-10-24', status: 'Selected', matchScore: 94 },
  { id: 'c-2', name: 'Darrell Steward', email: 'darrell.s@example.com', role: 'Product Manager', appliedDate: '2023-10-23', status: 'Interviewing', matchScore: 88 },
