'use client';

import React, { useState, useMemo, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  Search,
  MoreVertical,
  ChevronLeft,
  ChevronRight,
  UserRoundX,
  Mail,
  Calendar,
  Briefcase
} from 'lucide-react';

// ============================================================================
// 1. TYPES & INTERFACES
// ============================================================================

export type CandidateStatus = 'Selected' | 'Hold' | 'Rejected' | 'Interviewing' | 'Applied';

export interface Candidate {
  id: string;
  name: string;
  email: string;
  role: string;
  appliedDate: string;
  status: CandidateStatus;
  matchScore: number;
  avatarUrl?: string;
}

export interface RecentCandidatesTableProps {
  isLoading?: boolean;
  initialData?: Candidate[];
  title?: string;
  description?: string;
  onViewCandidate?: (id: string) => void;
}

// ============================================================================
// 2. MOCK DATA
// ============================================================================

